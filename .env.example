# Application
NODE_ENV=development
PORT=3000
APP_NAME=ease-commerce
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_NAME=ease_commerce
DB_DIALECT=mysql

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# UrbaneBolt Configuration
URBANEBOLT_API_URL=https://api.urbanebolt.com
URBANEBOLT_API_KEY=your_urbanebolt_api_key
URBANEBOLT_CLIENT_ID=your_urbanebolt_client_id
URBANEBOLT_CLIENT_SECRET=your_urbanebolt_client_secret

# Courier Configuration
COURIER_MAX_RETRIES=3
COURIER_RETRY_DELAY=1000
COURIER_TIMEOUT=30000

# Cache Configuration
CACHE_TTL=3600
AUTH_TOKEN_CACHE_TTL=1800

# Logging
LOG_FORMAT=combined
LOG_DIR=./logs

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# API Documentation
API_VERSION=v1
API_BASE_URL=http://localhost:3000/api

# External Services
MOCK_COURIER_ENABLED=true
